@page "/dashboard"
<div class="alert alert-success no-border-radius py-2">
    <i class="bi bi-check-lg"></i>
    대시보드에 오신 것을 환영합니다.
</div>
<div class="w-100" style="height: 380px">
    <div class="card h-100 w-100 no-border-radius">
        <div class="card-header d-flex justify-content-between">
            <span>배치</span>
            <div>
                <a class="link-body-emphasis p-0" href="#" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-three-dots-vertical"></i>
                </a>
                <ul class="dropdown-menu dropdown-menu-end shadow no-border-radius">
                    <li class="dropdown-item">새 배치 추가하기</li>
                    <li class="dropdown-item">배치 상세보기</li>
                </ul>
            </div>
        </div>
        @if (activeBatches.Count == 0)
        {
            <div class="card-body d-flex align-items-center align-content-center flex-column justify-content-center text-secondary">
                <div class="d-flex flex-column align-items-center align-content-center ">
                    <i class="bi bi-box-seam" style="font-size: 64px"></i>
                    가져갈 수 있는 원두가 없습니다.
                </div>
                <div class="btn btn-dark mt-4 no-border-radius">
                    <i class="bi bi-plus-lg"></i>
                    새 원두 배치 추가하기
                </div>
            </div>
        }
        else
        {
            
        }
    </div>
</div>
<div class="row mb-3">
    <div class="col-12 col-md-7 mt-3" style="height: 350px">
        <div class="card h-100 w-100 no-border-radius">
            <div class="card-header d-flex justify-content-between">
                <span>트랜젝션</span>
                <div>
                    <a class="link-body-emphasis p-0" href="#" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-three-dots-vertical"></i>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow no-border-radius">
                        <li class="dropdown-item">트랜젝션 상세 조회</li>
                    </ul>
                </div>
            </div>
            @if (recentTakes.Count == 0)
            {
                <div class="card-body d-flex align-items-center align-content-center flex-column justify-content-center text-secondary">
                    <div class="d-flex flex-column align-items-center align-content-center ">
                        <i class="bi bi-exclamation-triangle" style="font-size: 64px"></i>
                        표시할 데이터가 없습니다.
                    </div>
                </div>
            }
            else
            {

            }
        </div>
    </div>

    <div class="col-12 col-md-5 mt-3" style="height: 350px">
        <div class="card h-100 w-100 no-border-radius">
            <div class="card-header d-flex justify-content-between">
                <span>원두</span>
                <div>
                    <a class="link-body-emphasis p-0" href="#" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-three-dots-vertical"></i>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow no-border-radius">
                        <li class="dropdown-item" @onclick="OnItemAddBtnClick">원두 추가</li>
                    </ul>
                </div>
            </div>
            @if (items.Count == 0)
            {
                <div class="card-body d-flex align-items-center align-content-center flex-column justify-content-center text-secondary">
                    <div class="d-flex flex-column align-items-center align-content-center ">
                        <i class="bi bi-exclamation-triangle" style="font-size: 64px"></i>
                        표시할 데이터가 없습니다.
                    </div>
                </div>
            }
            else
            {
                <div id="items-accordion" class="card-body d-flex overflow-y-auto p-0 accordion flex-column">
                   <Virtualize Items="items" Context="item">
                        <div class="accordion-item w-100">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#item-@item.ItemId" aria-expanded="true" aria-controls="#item-@item.ItemId">
                                    <span class="fw-bold me-3">#@item.ItemId</span>
                                    <span>@item.ItemName</span>
                                </button>
                            </h2>
                            <div id="item-@item.ItemId" class="accordion-collapse collapse" data-bs-parent="#items-accordion">
                                <div class="accordion-body">
                                    <h6>상세 정보</h6>
                                    <div class="row">
                                        <div class="col-3">
                                            <span>설명</span>
                                        </div>
                                        <div class="col-9 text-wrap text-end">
                                            <span class="text-secondary">@{@(String.IsNullOrWhiteSpace(item.ItemDescription) ? "설명이 없습니다." : item.ItemDescription)}</span>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-3">
                                            <span>가격</span>
                                        </div>
                                        <div class="col-9 text-wrap text-end">
                                            <span class="text-secondary">@item.ItemPrice.ToString("N0")KRW</span>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-3">
                                            <span>용량</span>
                                        </div>
                                        <div class="col-9 text-wrap text-end">
                                            <span class="text-secondary">@item.ItemSize.ToString("N0")G</span>
                                        </div>
                                    </div>
                                    <hr/>
                                    <div class="d-flex gap-3">
                                        <button class="btn btn-outline-primary no-border-radius flex-grow-1" @onclick="async () => { await OnItemEditBtnClick(item); }">
                                            <i class="bi bi-pencil me-2"></i>
                                            편집
                                        </button>
                                        <button class="btn btn-outline-danger no-border-radius flex-grow-1" @onclick="async () => { await OnItemDeleteBtnClick(item); }">
                                            <i class="bi bi-x-lg me-2"></i>
                                            삭제
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </Virtualize>
                </div>
            }
        </div>
    </div>
</div>