@page "/" 
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation
@code{
    [CascadingParameter] private Task<AuthenticationState>? AuthenticationStateTask { get; set; }
    protected override async Task OnInitializedAsync()
    {
        bool _isAuthenticated = false;
        if (AuthenticationStateTask is not null)
        {
            var authState = await AuthenticationStateTask;
            _isAuthenticated = authState.User.Identity?.IsAuthenticated == true;
        }

        if (_isAuthenticated)
        {
            Navigation.NavigateTo("/main", forceLoad: true);
        }
    }
}

<PageTitle>CoffeeTime - 로그인</PageTitle>

<div class="d-flex justify-content-center align-items-center vh-100 signin-background">
    <div class="card col-11 col-md-6 row-md-6 shadow no-border-radius" style="max-width: 500px">
        <div class="card-header px-4 py-3">
            <div class="logo"></div>
        </div>
        <div class="card-body p-4">
            <h5 class="fw-bold">로그인</h5>
            <p class="text-secondary">CoffeeTime에 오신 것을 환영합니다.</p>
            <div class="alert alert-success py-2 no-border-radius mb-5">
                <i class="bi bi-check-lg me-1"></i>
                CloudInteractive ID로 로그인하십시오.
            </div>
            <a class="btn btn-primary w-100 no-border-radius py-2 d-flex justify-content-between" href="/oauth/signin">
                <div>클라우드인터렉티브 통합인증</div>
                <i class="bi bi-arrow-right"></i>
            </a>
        </div>
    </div>
</div>
